generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RolUsuario {
  PROVEEDOR
  CLIENTE
}

model Usuario {
  id        String      @id @default(cuid())
  email     String      @unique
  password  String
  nombre    String
  rol       RolUsuario  @default(CLIENTE)
  empresaId String?     @unique
  empresa   Empresa?    @relation("EmpresaUsuario", fields: [empresaId], references: [id])
  creadoEn  DateTime    @default(now())
  actualizadoEn DateTime @updatedAt
}

model Empresa {
  id                      String         @id @default(cuid())
  nombre                  String
  rif                     String?
  nif                     String?
  responsable             String?
  direccion               String?
  telefono                String?
  email                   String?
  telefonoWhatsapp        String         @unique
  promptSistema           String?
  calendlyUrl             String?
  googleCalendarId        String?
  googleRefreshToken      String?
  googleAccessToken       String?
  googleTokenExpiry       DateTime?
  usuario                 Usuario?       @relation("EmpresaUsuario")
  creadoEn                DateTime       @default(now())
  actualizadoEn           DateTime       @updatedAt
  conversaciones          Conversacion[]
  documentos              Documento[]
  contactos               Contacto[]
  memoria                 MemoriaEmpresa[]
  automatizaciones        Automatizacion[]
  citas                   Cita[]
}

model Cita {
  id                 String     @id @default(cuid())
  empresa            Empresa    @relation(fields: [empresaId], references: [id])
  empresaId          String
  contacto           Contacto?  @relation(fields: [contactoId], references: [id])
  contactoId         String?
  nombreCliente      String
  telefono           String
  inicio             DateTime
  fin                DateTime
  estado             EstadoCita @default(PENDIENTE)
  notas              String?
  googleEventId      String?
  googleCalendarLink String?
  creadoEn           DateTime   @default(now())
  actualizadoEn      DateTime   @updatedAt
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
}

model MemoriaEmpresa {
  id            String           @id @default(cuid())
  empresa       Empresa          @relation(fields: [empresaId], references: [id])
  empresaId     String
  categoria     CategoriaMemoria
  clave         String
  valor         String
  creadoEn      DateTime         @default(now())
  actualizadoEn DateTime         @updatedAt
}

enum CategoriaMemoria {
  PRODUCTO
  HORARIO
  PRECIO
  POLITICA
}

model Automatizacion {
  id            String      @id @default(cuid())
  empresa       Empresa     @relation(fields: [empresaId], references: [id])
  empresaId     String
  nombre        String
  trigger       TipoTrigger
  condicion     String?
  mensaje       String
  activa        Boolean     @default(true)
  ejecuciones   Int         @default(0)
  creadoEn      DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt
}

enum TipoTrigger {
  PRIMER_MENSAJE
  PALABRA_CLAVE
  FUERA_HORARIO
}

model Contacto {
  id             String         @id @default(cuid())
  empresa        Empresa        @relation(fields: [empresaId], references: [id])
  empresaId      String
  nombre         String?
  telefono       String
  tipo           TipoContacto   @default(LEAD)
  notas          String?
  creadoEn       DateTime       @default(now())
  actualizadoEn  DateTime       @updatedAt
  conversaciones Conversacion[]
  citas          Cita[]

  @@unique([empresaId, telefono])
}

model Conversacion {
  id             String       @id @default(cuid())
  empresa        Empresa      @relation(fields: [empresaId], references: [id])
  empresaId      String
  contacto       Contacto?    @relation(fields: [contactoId], references: [id])
  contactoId     String?
  numeroCliente  String
  estado         Estado       @default(ACTIVA)
  modoHumano     Boolean      @default(false)
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt
  mensajes       Mensaje[]
}

model Mensaje {
  id             String       @id @default(cuid())
  conversacion   Conversacion @relation(fields: [conversacionId], references: [id])
  conversacionId String
  contenido      String
  rol            Rol
  creadoEn       DateTime     @default(now())
}

model Documento {
  id          String            @id @default(cuid())
  empresa     Empresa           @relation(fields: [empresaId], references: [id])
  empresaId   String
  nombre      String
  contenido   String
  tipo        String            @default("texto")
  creadoEn    DateTime          @default(now())
  chunks      DocumentoChunk[]
}

model DocumentoChunk {
  id          String    @id @default(cuid())
  documento   Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  documentoId String
  empresaId   String
  contenido   String
  indice      Int
  creadoEn    DateTime  @default(now())
}

enum TipoContacto {
  LEAD
  CLIENTE
  PROVEEDOR
}

enum Estado {
  ACTIVA
  CERRADA
}

enum Rol {
  CLIENTE
  ASISTENTE
}
