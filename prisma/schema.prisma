generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  nombre        String
  rol           RolUsuario @default(CLIENTE)
  empresaId     String?    @unique
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt
  empresa       Empresa?   @relation("EmpresaUsuario", fields: [empresaId], references: [id])
}

model Empresa {
  id                 String           @id @default(cuid())
  nombre             String
  telefonoWhatsapp   String           @unique
  creadoEn           DateTime         @default(now())
  actualizadoEn      DateTime         @updatedAt
  promptSistema      String?
  calendlyUrl        String?
  googleAccessToken  String?
  googleCalendarId   String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  direccion          String?
  email              String?
  nif                String?
  responsable        String?
  rif                String?
  telefono           String?
  automatizaciones   Automatizacion[]
  citas              Cita[]
  contactos          Contacto[]
  conversaciones     Conversacion[]
  documentos         Documento[]
  memoria            MemoriaEmpresa[]
  usuario            Usuario?         @relation("EmpresaUsuario")
}

model Cita {
  id                 String     @id @default(cuid())
  empresaId          String
  contactoId         String?
  nombreCliente      String
  telefono           String
  inicio             DateTime
  fin                DateTime
  estado             EstadoCita @default(PENDIENTE)
  notas              String?
  creadoEn           DateTime   @default(now())
  actualizadoEn      DateTime   @updatedAt
  googleCalendarLink String?
  googleEventId      String?
  contacto           Contacto?  @relation(fields: [contactoId], references: [id])
  empresa            Empresa    @relation(fields: [empresaId], references: [id])
}

model MemoriaEmpresa {
  id            String           @id @default(cuid())
  empresaId     String
  categoria     CategoriaMemoria
  clave         String
  valor         String
  creadoEn      DateTime         @default(now())
  actualizadoEn DateTime         @updatedAt
  empresa       Empresa          @relation(fields: [empresaId], references: [id])
}

model Automatizacion {
  id            String      @id @default(cuid())
  empresaId     String
  nombre        String
  trigger       TipoTrigger
  condicion     String?
  mensaje       String
  activa        Boolean     @default(true)
  ejecuciones   Int         @default(0)
  creadoEn      DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt
  empresa       Empresa     @relation(fields: [empresaId], references: [id])
}

model Contacto {
  id             String         @id @default(cuid())
  empresaId      String
  nombre         String?
  telefono       String
  tipo           TipoContacto   @default(LEAD)
  notas          String?
  creadoEn       DateTime       @default(now())
  actualizadoEn  DateTime       @updatedAt
  citas          Cita[]
  empresa        Empresa        @relation(fields: [empresaId], references: [id])
  conversaciones Conversacion[]

  @@unique([empresaId, telefono])
}

model Conversacion {
  id            String    @id @default(cuid())
  empresaId     String
  numeroCliente String
  estado        Estado    @default(ACTIVA)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  modoHumano    Boolean   @default(false)
  contactoId    String?
  contacto      Contacto? @relation(fields: [contactoId], references: [id])
  empresa       Empresa   @relation(fields: [empresaId], references: [id])
  mensajes      Mensaje[]
}

model Mensaje {
  id             String       @id @default(cuid())
  conversacionId String
  contenido      String
  rol            Rol
  creadoEn       DateTime     @default(now())
  conversacion   Conversacion @relation(fields: [conversacionId], references: [id])
}

model Documento {
  id        String           @id @default(cuid())
  empresaId String
  nombre    String
  contenido String
  tipo      String           @default("texto")
  creadoEn  DateTime         @default(now())
  empresa   Empresa          @relation(fields: [empresaId], references: [id])
  chunks    DocumentoChunk[]
}

model DocumentoChunk {
  id          String    @id @default(cuid())
  documentoId String
  empresaId   String
  contenido   String
  indice      Int
  creadoEn    DateTime  @default(now())
  documento   Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
}

enum RolUsuario {
  PROVEEDOR
  CLIENTE
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
}

enum CategoriaMemoria {
  PRODUCTO
  HORARIO
  PRECIO
  POLITICA
}

enum TipoTrigger {
  PRIMER_MENSAJE
  PALABRA_CLAVE
  FUERA_HORARIO
}

enum TipoContacto {
  LEAD
  CLIENTE
  PROVEEDOR
}

enum Estado {
  ACTIVA
  CERRADA
}

enum Rol {
  CLIENTE
  ASISTENTE
}
