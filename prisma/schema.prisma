generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                 String     @id @default(cuid())
  email              String     @unique
  password           String?    // Opcional para usuarios OAuth
  nombre             String
  rol                RolUsuario @default(CLIENTE)
  empresaId          String?    @unique
  image              String?    // Avatar de Google/OAuth
  emailVerified      DateTime?  // Para NextAuth
  creadoEn           DateTime   @default(now())
  actualizadoEn      DateTime   @updatedAt
  empresa            Empresa?   @relation("EmpresaUsuario", fields: [empresaId], references: [id])
  accounts           Account[]  // Cuentas OAuth vinculadas
  sessions           Session[]  // Sesiones de NextAuth
  ticketsCreados     Ticket[]   @relation("TicketCreador")
  ticketsAsignados   Ticket[]   @relation("TicketAsignado")
  mensajesTicket     MensajeTicket[]
}

model Empresa {
  id                    String              @id @default(cuid())
  nombre                String
  telefonoWhatsapp      String              @unique
  creadoEn              DateTime            @default(now())
  actualizadoEn         DateTime            @updatedAt

  // Plan y suscripción
  planId                String?
  plan                  Plan?               @relation(fields: [planId], references: [id])
  estadoPlan            EstadoPlan          @default(TRIAL)
  fechaVencimiento      DateTime?

  // Contadores mensuales (resetear cada mes)
  conversacionesEsteMes Int                 @default(0)
  ultimoResetContador   DateTime            @default(now())

  // Configuración
  promptSistema         String?
  calendlyUrl           String?
  googleAccessToken     String?
  googleCalendarId      String?
  googleRefreshToken    String?
  googleTokenExpiry     DateTime?
  direccion             String?
  email                 String?
  nif                   String?             @unique
  responsable           String?
  rif                   String?             @unique
  telefono              String?

  // Relaciones
  agentes               Agente[]
  automatizaciones      Automatizacion[]
  citas                 Cita[]
  contactos             Contacto[]
  conversaciones        Conversacion[]
  documentos            Documento[]
  memoria               MemoriaEmpresa[]
  numerosWhatsApp       NumeroWhatsApp[]
  pushSubscriptions     PushSubscription[]
  usuario               Usuario?            @relation("EmpresaUsuario")
}

model NumeroWhatsApp {
  id                String          @id @default(cuid())
  empresaId         String
  telefono          String          @unique // Número en formato internacional +584241234567
  nombre            String?         // Nombre/alias del número (ej: "Soporte", "Ventas")
  activo            Boolean         @default(true)
  esPrincipal       Boolean         @default(false) // Solo uno puede ser principal
  creadoEn          DateTime        @default(now())
  actualizadoEn     DateTime        @updatedAt

  // Relaciones
  empresa           Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  conversaciones    Conversacion[]

  @@index([empresaId])
  @@index([telefono])
}

model Agente {
  id                String          @id @default(cuid())
  empresaId         String
  nombre            String          // Ej: "Atención al Cliente", "Ventas", "Soporte Técnico"
  descripcion       String?         // Breve descripción del agente
  prompt            String          // Prompt personalizado del agente
  activo            Boolean         @default(true)
  color             String?         // Color en hex para UI (ej: "#3B82F6")

  // Configuración de ruteo
  esPrincipal       Boolean         @default(false) // Agente por defecto
  palabrasClave     String[]        // Keywords para ruteo automático
  horarioInicio     String?         // Ej: "09:00"
  horarioFin        String?         // Ej: "18:00"
  diasSemana        Int[]           // 0=Domingo, 1=Lunes, ... 6=Sábado

  creadoEn          DateTime        @default(now())
  actualizadoEn     DateTime        @updatedAt

  // Relaciones
  empresa           Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  conversaciones    Conversacion[]
  transferenciasOrigen TransferenciaAgente[] @relation("TransferenciaOrigen")
  transferenciasDestino TransferenciaAgente[] @relation("TransferenciaDestino")

  @@index([empresaId])
  @@index([activo])
}

model TransferenciaAgente {
  id                String       @id @default(cuid())
  conversacionId    String
  agenteOrigenId    String?      // Null si viene del sistema general
  agenteDestinoId   String
  motivo            String?      // Razón de la transferencia
  aprobada          Boolean      @default(false)
  creadoEn          DateTime     @default(now())

  conversacion      Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  agenteOrigen      Agente?      @relation("TransferenciaOrigen", fields: [agenteOrigenId], references: [id])
  agenteDestino     Agente       @relation("TransferenciaDestino", fields: [agenteDestinoId], references: [id])

  @@index([conversacionId])
  @@index([agenteOrigenId])
  @@index([agenteDestinoId])
}

model Cita {
  id                 String     @id @default(cuid())
  empresaId          String
  contactoId         String?
  nombreCliente      String
  telefono           String
  inicio             DateTime
  fin                DateTime
  estado             EstadoCita @default(PENDIENTE)
  notas              String?
  creadoEn           DateTime   @default(now())
  actualizadoEn      DateTime   @updatedAt
  googleCalendarLink String?
  googleEventId      String?
  contacto           Contacto?  @relation(fields: [contactoId], references: [id])
  empresa            Empresa    @relation(fields: [empresaId], references: [id])
}

model MemoriaEmpresa {
  id            String           @id @default(cuid())
  empresaId     String
  categoria     CategoriaMemoria
  clave         String
  valor         String
  creadoEn      DateTime         @default(now())
  actualizadoEn DateTime         @updatedAt
  empresa       Empresa          @relation(fields: [empresaId], references: [id])
}

model Automatizacion {
  id            String      @id @default(cuid())
  empresaId     String
  nombre        String
  trigger       TipoTrigger
  condicion     String?
  mensaje       String
  activa        Boolean     @default(true)
  ejecuciones   Int         @default(0)
  creadoEn      DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt
  empresa       Empresa     @relation(fields: [empresaId], references: [id])
}

model Contacto {
  id             String         @id @default(cuid())
  empresaId      String
  nombre         String?
  telefono       String
  tipo           TipoContacto   @default(LEAD)
  notas          String?
  creadoEn       DateTime       @default(now())
  actualizadoEn  DateTime       @updatedAt
  citas          Cita[]
  empresa        Empresa        @relation(fields: [empresaId], references: [id])
  conversaciones Conversacion[]

  @@unique([empresaId, telefono])
}

model Conversacion {
  id               String                  @id @default(cuid())
  empresaId        String
  numeroCliente    String
  numeroWhatsAppId String?                 // Nullable para migrar datos existentes
  agenteId         String?                 // Agente asignado a esta conversación
  estado           Estado                  @default(ACTIVA)
  creadoEn         DateTime                @default(now())
  actualizadoEn    DateTime                @updatedAt
  modoHumano       Boolean                 @default(false)
  contactoId       String?
  contacto         Contacto?               @relation(fields: [contactoId], references: [id])
  empresa          Empresa                 @relation(fields: [empresaId], references: [id])
  numeroWhatsApp   NumeroWhatsApp?         @relation(fields: [numeroWhatsAppId], references: [id])
  agente           Agente?                 @relation(fields: [agenteId], references: [id])
  mensajes         Mensaje[]
  transferencias   TransferenciaAgente[]

  @@index([numeroWhatsAppId])
  @@index([agenteId])
}

model Mensaje {
  id             String       @id @default(cuid())
  conversacionId String
  contenido      String
  rol            Rol
  creadoEn       DateTime     @default(now())
  conversacion   Conversacion @relation(fields: [conversacionId], references: [id])
}

model Documento {
  id        String           @id @default(cuid())
  empresaId String
  nombre    String
  contenido String
  tipo      String           @default("texto")
  creadoEn  DateTime         @default(now())
  empresa   Empresa          @relation(fields: [empresaId], references: [id])
  chunks    DocumentoChunk[]
}

model DocumentoChunk {
  id          String    @id @default(cuid())
  documentoId String
  empresaId   String
  contenido   String
  indice      Int
  creadoEn    DateTime  @default(now())
  documento   Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
}

enum RolUsuario {
  PROVEEDOR
  CLIENTE
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
}

enum CategoriaMemoria {
  PRODUCTO
  HORARIO
  PRECIO
  POLITICA
}

enum TipoTrigger {
  PRIMER_MENSAJE
  PALABRA_CLAVE
  FUERA_HORARIO
}

enum TipoContacto {
  LEAD
  CLIENTE
  PROVEEDOR
}

enum Estado {
  ACTIVA
  CERRADA
}

enum Rol {
  CLIENTE
  ASISTENTE
}

model PushSubscription {
  id            String   @id @default(cuid())
  empresaId     String
  endpoint      String
  p256dh        String
  auth          String
  userAgent     String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  empresa       Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, endpoint])
  @@index([empresaId])
}

// Modelos de NextAuth para OAuth
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  usado     Boolean  @default(false)
  creadoEn  DateTime @default(now())

  @@index([email])
  @@index([token])
}

model Ticket {
  id            String         @id @default(cuid())
  titulo        String
  descripcion   String
  estado        EstadoTicket   @default(ABIERTO)
  prioridad     PrioridadTicket @default(MEDIA)
  categoria     CategoriaTicket @default(GENERAL)
  creadoPorId   String
  asignadoAId   String?
  empresaId     String?
  creadoEn      DateTime       @default(now())
  actualizadoEn DateTime       @updatedAt
  cerradoEn     DateTime?
  creadoPor     Usuario        @relation("TicketCreador", fields: [creadoPorId], references: [id])
  asignadoA     Usuario?       @relation("TicketAsignado", fields: [asignadoAId], references: [id])
  mensajes      MensajeTicket[]

  @@index([creadoPorId])
  @@index([asignadoAId])
  @@index([estado])
  @@index([empresaId])
}

model MensajeTicket {
  id          String   @id @default(cuid())
  ticketId    String
  usuarioId   String
  mensaje     String
  esInterno   Boolean  @default(false)
  creadoEn    DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([ticketId])
  @@index([usuarioId])
}

model Plan {
  id                    String    @id @default(cuid())
  nombre                String    @unique // "STARTER", "BUSINESS", "CORPORATIVO"
  descripcion           String?
  precio                Float     // Precio mensual en USD o EUR
  precioMXN             Float?    // Opcional: precio en moneda local

  // Límites
  maxWhatsApps          Int       // 1, 3, 10
  maxAgentes            Int       // 3, 10, -1 (ilimitado = -1)
  maxConversacionesMes  Int       // 500, 2000, 10000
  maxDocumentosMB       Int       // 10, 100, -1 (ilimitado)

  // Features
  transferenciaAgentes  Boolean   @default(false)
  ruteoInteligente      Boolean   @default(false)
  analyticsAvanzados    Boolean   @default(false)
  apiPersonalizada      Boolean   @default(false)
  soportePrioritario    Boolean   @default(false)
  horariosPersonalizados Boolean  @default(false)

  // Orden para mostrar en UI
  orden                 Int       @default(0)
  visible               Boolean   @default(true)

  empresas              Empresa[]
  creadoEn              DateTime  @default(now())
  actualizadoEn         DateTime  @updatedAt
}

enum EstadoPlan {
  TRIAL
  ACTIVO
  SUSPENDIDO
  CANCELADO
}

enum EstadoTicket {
  ABIERTO
  EN_PROGRESO
  RESUELTO
  CERRADO
}

enum PrioridadTicket {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum CategoriaTicket {
  GENERAL
  TECNICO
  FACTURACION
  FUNCIONALIDAD
  BUG
  MEJORA
}
